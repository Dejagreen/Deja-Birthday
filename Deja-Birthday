<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deja's Birthday Dinner</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://unpkg.com/lucide@latest"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400&family=Great+Vibes&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
            serif: ['Playfair Display', 'serif'],
            script: ['Great Vibes', 'cursive'],
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    .font-serif { font-family: 'Playfair Display', serif; }
    .font-script { font-family: 'Great Vibes', cursive; }

    @keyframes float {
      0%, 100% { transform: translateY(0) rotate(0deg); }
      50% { transform: translateY(-12px) rotate(2deg); }
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes scaleIn {
      from { opacity: 0; transform: scale(0.8); }
      to { opacity: 1; transform: scale(1); }
    }
    @keyframes sparkle {
      0%, 100% { opacity: 0.3; transform: scale(0.8); }
      50% { opacity: 1; transform: scale(1.2); }
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .animate-float { animation: float 6s ease-in-out infinite; }
    .animate-fade-in-up { animation: fadeInUp 0.8s ease-out forwards; }
    .animate-fade-in { animation: fadeIn 1s ease-out forwards; }
    .animate-scale-in { animation: scaleIn 0.6s ease-out forwards; }
    .animate-sparkle { animation: sparkle 3s ease-in-out infinite; }
    .animate-slide-down { animation: slideDown 0.4s ease-out forwards; }

    .delay-100 { animation-delay: 0.1s; }
    .delay-200 { animation-delay: 0.2s; }
    .delay-300 { animation-delay: 0.3s; }
    .delay-400 { animation-delay: 0.4s; }
    .delay-500 { animation-delay: 0.5s; }
    .delay-600 { animation-delay: 0.6s; }
    .delay-700 { animation-delay: 0.7s; }
    .delay-800 { animation-delay: 0.8s; }
    .delay-900 { animation-delay: 0.9s; }

    .opacity-start { opacity: 0; }

    details summary::-webkit-details-marker { display: none; }
    details summary { list-style: none; }

    .toast-enter { animation: slideDown 0.4s ease-out forwards; }
  </style>
</head>
<body class="bg-[#0a0a0a] text-white min-h-screen overflow-x-hidden">

  <div class="fixed inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="fixed top-20 -left-32 w-96 h-96 bg-rose-500/10 rounded-full blur-[120px] animate-float"></div>
  <div class="fixed bottom-20 -right-32 w-96 h-96 bg-amber-500/10 rounded-full blur-[120px] animate-float" style="animation-delay: -3s;"></div>
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-rose-900/5 rounded-full blur-[150px]"></div>

  <div class="relative z-10 max-w-2xl mx-auto px-6 py-12 md:py-20">

    <div class="flex justify-center gap-8 mb-8 opacity-start animate-fade-in">
      <span class="text-rose-400/60 animate-sparkle text-lg">✦</span>
      <span class="text-amber-400/60 animate-sparkle text-sm" style="animation-delay: 1s;">✦</span>
      <span class="text-rose-400/60 animate-sparkle text-lg" style="animation-delay: 0.5s;">✦</span>
    </div>

    <div class="text-center mb-16 opacity-start animate-fade-in-up">
      <p class="text-stone-500 text-xs font-medium tracking-[0.25em] uppercase mb-4">You're Invited To</p>
      <h1 class="font-script text-5xl md:text-7xl text-rose-300 mb-2">Deja's</h1>
      <h2 class="font-serif text-3xl md:text-4xl font-500 tracking-tight text-white/90 mb-4">Birthday Dinner</h2>
      <div class="inline-flex items-center gap-2 mt-6 px-5 py-2 rounded-full border border-white/10 bg-white/5 backdrop-blur-sm">
        <span class="w-2 h-2 rounded-full bg-rose-400 animate-pulse"></span>
        <span class="text-sm text-stone-300 font-medium">Turning 24</span>
      </div>
    </div>

    <div class="text-center mb-20 opacity-start animate-scale-in delay-300">
      <span class="font-serif text-[120px] md:text-[160px] leading-none text-white/[0.03] select-none">24</span>
    </div>

    <div class="relative mb-8 opacity-start animate-fade-in-up delay-200">
      <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-8 backdrop-blur-sm hover:bg-white/[0.06] transition-all duration-500">
        <div class="flex items-center gap-4 mb-6">
          <div class="w-10 h-10 rounded-xl bg-rose-500/10 flex items-center justify-center">
            <i data-lucide="calendar-heart" class="w-5 h-5 text-rose-400"></i>
          </div>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500">The Date</p>
        </div>
        <div class="flex items-baseline gap-3">
          <span class="font-serif text-5xl md:text-6xl text-white">May 3</span>
          <span class="text-stone-500 text-lg">Sunday</span>
        </div>
        <p class="text-stone-400 mt-2 text-sm">2026</p>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
      <div class="opacity-start animate-fade-in-up delay-300">
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-6 backdrop-blur-sm hover:bg-white/[0.06] transition-all duration-500 h-full">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-amber-500/10 flex items-center justify-center">
              <i data-lucide="clock" class="w-4 h-4 text-amber-400"></i>
            </div>
            <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500">Time</p>
          </div>
          <p class="font-serif text-2xl text-white">6:00 PM</p>
          <p class="text-stone-500 text-sm mt-1">Come a little early if you can</p>
        </div>
      </div>

      <div class="opacity-start animate-fade-in-up delay-400">
        <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-6 backdrop-blur-sm hover:bg-white/[0.06] transition-all duration-500 h-full">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-9 h-9 rounded-lg bg-rose-500/10 flex items-center justify-center">
              <i data-lucide="map-pin" class="w-4 h-4 text-rose-400"></i>
            </div>
            <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500">Where</p>
          </div>
          <p class="font-serif text-2xl text-white">Gringos</p>
          <p class="text-stone-500 text-sm mt-1">Mexican Kitchen</p>
          <a href="https://www.google.com/maps/search/19330+I-45+Spring+TX+77373" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 mt-3 text-xs text-rose-400/70 hover:text-rose-300 transition-colors duration-300">
            <i data-lucide="navigation" class="w-3 h-3"></i>
            <span>19330 I-45, Spring, TX 77373</span>
          </a>
        </div>
      </div>
    </div>

    <div class="mb-8 opacity-start animate-fade-in-up delay-500">
      <div class="bg-gradient-to-br from-rose-500/[0.08] to-amber-500/[0.05] border border-rose-500/[0.1] rounded-2xl p-8 backdrop-blur-sm">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-9 h-9 rounded-lg bg-rose-500/15 flex items-center justify-center">
            <i data-lucide="sparkles" class="w-4 h-4 text-rose-400"></i>
          </div>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-rose-300/70">The Vibe</p>
        </div>
        <p class="text-white/90 text-lg font-serif mb-3">Fun-Casual</p>
        <p class="text-stone-400 text-sm leading-relaxed">
          Come as you are. Good food, good people, great energy. No stress about the outfit — just bring your vibe and your appetite.
        </p>
        <div class="flex flex-wrap gap-2 mt-5">
          <span class="px-3 py-1 rounded-full text-xs bg-white/5 border border-white/10 text-stone-400">Tacos & Drinks</span>
          <span class="px-3 py-1 rounded-full text-xs bg-white/5 border border-white/10 text-stone-400">Laughter</span>
          <span class="px-3 py-1 rounded-full text-xs bg-white/5 border border-white/10 text-stone-400">Good Music</span>
          <span class="px-3 py-1 rounded-full text-xs bg-white/5 border border-white/10 text-stone-400">Vibes Only</span>
        </div>
      </div>
    </div>

    <div class="mb-8 opacity-start animate-fade-in-up delay-600">
      <div class="flex items-start gap-4 px-2">
        <span class="text-amber-400/50 text-sm mt-0.5">💛</span>
        <p class="text-stone-500 text-sm leading-relaxed italic">
          Gifts aren't required at all, but if you want to bring something — Deja won't complain! Just showing up and having a good time is what matters most.
        </p>
      </div>
    </div>

    <div class="mb-8 opacity-start animate-fade-in-up delay-700">
      <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl p-8 backdrop-blur-sm">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-9 h-9 rounded-lg bg-white/10 flex items-center justify-center">
            <i data-lucide="heart" class="w-4 h-4 text-white/70"></i>
          </div>
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500">RSVP</p>
        </div>
        <p class="text-stone-400 text-sm mb-6">Let Deja know if you'll be there ✨</p>

        <form id="rsvpForm" class="space-y-4" action="https://formspree.io/f/xkokopqw" method="POST">
          <div>
            <input
              type="text"
              name="name"
              id="nameInput"
              placeholder="Your name"
              required
              class="w-full bg-white/[0.05] border border-white/[0.1] rounded-xl px-4 py-3 text-sm text-white placeholder:text-stone-600 focus:outline-none focus:border-rose-500/50 focus:bg-white/[0.07] transition-all duration-300"
            />
          </div>
          <div>
            <select
              name="response"
              id="rsvpSelect"
              required
              class="w-full bg-white/[0.05] border border-white/[0.1] rounded-xl px-4 py-3 text-sm text-stone-400 focus:outline-none focus:border-rose-500/50 focus:bg-white/[0.07] transition-all duration-300 appearance-none cursor-pointer"
              style="background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%2378716c%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>'); background-repeat: no-repeat; background-position: right 16px center;"
            >
              <option value="" disabled selected>Are you coming?</option>
              <option value="yes" class="bg-[#1a1a1a]">I'll be there! 💛</option>
              <option value="maybe" class="bg-[#1a1a1a]">Maybe — let me check</option>
              <option value="no" class="bg-[#1a1a1a]">Can't make it 😢</option>
            </select>
          </div>
          <div id="plusOneWrapper" class="hidden">
            <label class="flex items-center gap-3 cursor-pointer group">
              <div class="relative">
                <input type="checkbox" name="plus_one" id="plusOne" class="sr-only peer" value="yes" />
                <div class="w-10 h-6 bg-white/10 rounded-full peer-checked:bg-rose-500/40 transition-colors duration-300"></div>
                <div class="absolute left-0.5 top-0.5 w-5 h-5 bg-stone-400 rounded-full peer-checked:translate-x-4 peer-checked:bg-rose-400 transition-all duration-300"></div>
              </div>
              <span class="text-sm text-stone-400 group-hover:text-stone-300 transition-colors">Bringing a plus one?</span>
            </label>
          </div>
          <div id="noteWrapper" class="hidden">
            <textarea
              name="note"
              id="noteInput"
              placeholder="Anything Deja should know? (allergies, dietary prefs, etc.)"
              rows="2"
              class="w-full bg-white/[0.05] border border-white/[0.1] rounded-xl px-4 py-3 text-sm text-white placeholder:text-stone-600 focus:outline-none focus:border-rose-500/50 focus:bg-white/[0.07] transition-all duration-300 resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            id="rsvpBtn"
            class="w-full bg-white text-stone-900 font-medium text-sm py-3 rounded-xl hover:bg-stone-100 transition-all duration-300 active:scale-[0.98]"
          >
            Send RSVP
          </button>
        </form>

        <div id="rsvpSuccess" class="hidden text-center py-6">
          <div class="w-14 h-14 rounded-full bg-rose-500/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="check" class="w-6 h-6 text-rose-400"></i>
          </div>
          <p class="font-serif text-xl text-white mb-1">You're in! 🎉</p>
          <p class="text-stone-500 text-sm">Deja can't wait to see you at Gringos.</p>
        </div>

        <div id="rsvpError" class="hidden text-center py-6">
          <div class="w-14 h-14 rounded-full bg-red-500/15 flex items-center justify-center mx-auto mb-4">
            <i data-lucide="alert-circle" class="w-6 h-6 text-red-400"></i>
          </div>
          <p class="font-serif text-xl text-white mb-1">Hmm, something went wrong</p>
          <p class="text-stone-500 text-sm mb-4">Try again or text Deja directly.</p>
          <button onclick="resetForm()" class="text-xs text-rose-400/70 hover:text-rose-300 transition-colors">Try again</button>
        </div>
      </div>
    </div>

    <div class="mb-16 opacity-start animate-fade-in-up delay-800">
      <div class="bg-white/[0.04] border border-white/[0.08] rounded-2xl overflow-hidden backdrop-blur-sm">
        <div class="px-8 pt-6 pb-2">
          <p class="text-xs font-medium tracking-[0.2em] uppercase text-stone-500">Quick Q's</p>
        </div>

        <details class="group border-t border-white/[0.06]">
          <summary class="flex items-center justify-between px-8 py-4 cursor-pointer hover:bg-white/[0.02] transition-colors">
            <span class="text-sm text-stone-300">How does the bill work?</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-stone-600 group-open:rotate-180 transition-transform duration-300"></i>
          </summary>
          <div class="px-8 pb-4">
            <p class="text-stone-500 text-sm leading-relaxed">Everyone will have their own separate check — so you just pay for what you order. No splitting, no math, no stress 😊</p>
          </div>
        </details>

        <details class="group border-t border-white/[0.06]">
          <summary class="flex items-center justify-between px-8 py-4 cursor-pointer hover:bg-white/[0.02] transition-colors">
            <span class="text-sm text-stone-300">Should I bring a gift?</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-stone-600 group-open:rotate-180 transition-transform duration-300"></i>
          </summary>
          <div class="px-8 pb-4">
            <p class="text-stone-500 text-sm leading-relaxed">Totally up to you! Gifts aren't expected, but if you feel like bringing something Deja definitely won't mind. No pressure either way 🤍</p>
          </div>
        </details>

        <details class="group border-t border-white/[0.06]">
          <summary class="flex items-center justify-between px-8 py-4 cursor-pointer hover:bg-white/[0.02] transition-colors">
            <span class="text-sm text-stone-300">What should I wear?</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-stone-600 group-open:rotate-180 transition-transform duration-300"></i>
          </summary>
          <div class="px-8 pb-4">
            <p class="text-stone-500 text-sm leading-relaxed">Fun-casual! Think cute but comfortable. No need to overdress — jeans and a nice top works perfectly.</p>
          </div>
        </details>

        <details class="group border-t border-white/[0.06]">
          <summary class="flex items-center justify-between px-8 py-4 cursor-pointer hover:bg-white/[0.02] transition-colors">
            <span class="text-sm text-stone-300">Can I bring a plus one?</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-stone-600 group-open:rotate-180 transition-transform duration-300"></i>
          </summary>
          <div class="px-8 pb-4">
            <p class="text-stone-500 text-sm leading-relaxed">Just let Deja know when you RSVP so she can plan accordingly.</p>
          </div>
        </details>

        <details class="group border-t border-white/[0.06]">
          <summary class="flex items-center justify-between px-8 py-4 cursor-pointer hover:bg-white/[0.02] transition-colors">
            <span class="text-sm text-stone-300">When do I need to RSVP by?</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-stone-600 group-open:rotate-180 transition-transform duration-300"></i>
          </summary>
          <div class="px-8 pb-4">
            <p class="text-stone-500 text-sm leading-relaxed">Ideally by April 28 — but the sooner the better so Deja can lock in the reservation at Gringos.</p>
          </div>
        </details>
      </div>
    </div>

    <div class="text-center opacity-start animate-fade-in delay-900">
      <div class="flex justify-center gap-6 mb-6">
        <span class="text-rose-400/40 animate-sparkle text-xs">✦</span>
        <span class="text-amber-400/40 animate-sparkle text-[10px]" style="animation-delay: 1.5s;">✦</span>
        <span class="text-rose-400/40 animate-sparkle text-xs" style="animation-delay: 0.8s;">✦</span>
      </div>
      <p class="font-script text-2xl text-rose-300/40 mb-2">See you at Gringos</p>
      <p class="text-stone-700 text-xs tracking-wider">May 3, 2026 — Deja's 24th</p>
    </div>

  </div>

  <div id="toastContainer" class="fixed top-6 right-6 z-50 flex flex-col gap-2"></div>

  <script>
    lucide.createIcons();

    const rsvpSelect = document.getElementById('rsvpSelect');
    const plusOneWrapper = document.getElementById('plusOneWrapper');
    const noteWrapper = document.getElementById('noteWrapper');
    const rsvpForm = document.getElementById('rsvpForm');
    const rsvpSuccess = document.getElementById('rsvpSuccess');
    const rsvpError = document.getElementById('rsvpError');
    const rsvpBtn = document.getElementById('rsvpBtn');

    rsvpSelect.addEventListener('change', (e) => {
      const val = e.target.value;
      plusOneWrapper.classList.toggle('hidden', val === 'no');
      noteWrapper.classList.remove('hidden');
      rsvpSelect.classList.remove('text-stone-400');
      rsvpSelect.classList.add('text-white');
    });

    rsvpForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('nameInput').value.trim();
      const response = rsvpSelect.value;
      if (!name || !response) return;

      rsvpBtn.disabled = true;
      rsvpBtn.textContent = 'Sending...';
      rsvpBtn.classList.add('opacity-70');

      const formData = new FormData(rsvpForm);

      fetch('https://formspree.io/f/xkokopqw', {
        method: 'POST',
        body: formData,
        headers: { 'Accept': 'application/json' }
      })
      .then(response => {
        if (response.ok) {
          showSuccess(name);
        } else {
          throw new Error('Failed');
        }
      })
      .catch(() => {
        showError();
      });
    });

    function showSuccess(name) {
      rsvpForm.classList.add('hidden');
      rsvpError.classList.add('hidden');
      rsvpSuccess.classList.remove('hidden');
      rsvpSuccess.classList.add('animate-scale-in');

      const response = rsvpSelect.value;
      const messages = {
        yes: `${name}, you're confirmed! 🎉`,
        maybe: `Got it, ${name}! Deja will follow up 💛`,
        no: `We'll miss you, ${name}! 😢`
      };
      showToast(messages[response] || 'RSVP received! ✨');
      lucide.createIcons();
    }

    function showError() {
      rsvpForm.classList.add('hidden');
      rsvpError.classList.remove('hidden');
      rsvpError.classList.add('animate-scale-in');
      lucide.createIcons();
    }

    function resetForm() {
      rsvpForm.classList.remove('hidden');
      rsvpError.classList.add('hidden');
      rsvpBtn.disabled = false;
      rsvpBtn.textContent = 'Send RSVP';
      rsvpBtn.classList.remove('opacity-70');
    }

    function showToast(message) {
      const container = document.getElementById('toastContainer');
      const toast = document.createElement('div');
      toast.className = 'toast-enter bg-white/10 backdrop-blur-md border border-white/10 rounded-xl px-5 py-3 text-sm text-white/90 shadow-2xl';
      toast.textContent = message;
      container.appendChild(toast);

      setTimeout(() => {
        toast.style.transition = 'opacity 0.4s ease, transform 0.4s ease';
        toast.style.opacity = '0';
        toast.style.transform = 'translateY(-10px)';
        setTimeout(() => toast.remove(), 400);
      }, 3500);
    }
  </script>
</body>
</html>
